{
    "manifest_version": 3,
    "name": "corenominal Custom New Tab",
    "version": "1.0.3",
    "description": "Changes the new tab page to a specified URL.",
    "permissions": [
        "tabs",
        "storage"
    ],
    "action": {
        "default_area": "navbar",
        "default_title": "Custom New Tab"
    },
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "icons": {
        "16": "assets/img/icon-16.png",
        "32": "assets/img/icon-32.png",
        "48": "assets/img/icon-48.png",
        "128": "assets/img/icon-128.png"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "browser_specific_settings": {
        "gecko": {
        "id": "customnewtab@corenominal.com"
        }
    },
    "background": {
        "scripts": ["assets/js/background.js"],
        "service_worker": "assets/js/background.js"
     }
}

